    {{ form_start(form) }}
    {{ form_widget(form) }}
    {{ form_end(form) }}


        <aside class="col-12 col-md-3 col-lg-2 mb-3">
            <div class="card">
                <div class="card-header">Subscribers</div>
                <ul class="list-group list-group-flush">
                    {% for s in subscribers %}
                        <li class="list-group-item">
                            <a href="{{ path('app_profile', { id: s.follower.id }) }}">
                                {{ s.follower.username }}
                            </a>
                        </li>
                    {% else %}
                        <li class="list-group-item text-muted">No subscribers yet</li>
                    {% endfor %}
                </ul>
            </div>
        </aside>

    <a href="{{ path('app_logout') }}">Logout</a>
{% endblock %}
